# ─── NEXT AUTH ───────────────────────────────────────────────────
# Generá un secret random: openssl rand -base64 32
NEXTAUTH_SECRET=TU_SECRET_RANDOM_ACA
NEXTAUTH_URL=https://TU_DOMINIO.vercel.app

# ─── GOOGLE OAUTH ─────────────────────────────────────────────────
# Creá credenciales en: https://console.cloud.google.com
# Tipo: OAuth 2.0 Web Application
# Authorized redirect URIs: https://TU_DOMINIO.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID=TU_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=TU_GOOGLE_CLIENT_SECRET

# ─── DOMINIO PERMITIDO (opcional) ─────────────────────────────────
# Si querés restringir a un dominio propio de Google Workspace
# Dejá vacío para permitir cualquier cuenta Gmail
ALLOWED_DOMAIN=galas.com.ar

# ─── PRODUCTIVIDAD ────────────────────────────────────────────────
# Mínimo de eventos VERDES por día para considerarse productivo
NEXT_PUBLIC_PRODUCTIVITY_GOAL=10
